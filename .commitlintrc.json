{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "docs", "chore", "perf", "refactor", "test", "style", "build", "ci"]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "amazon",
        "find-orders",
        "shop-amazon",
        "write-reviews",
        "audit-rendered-ui",
        "design-frontend",
        "refactor-ui",
        "release",
        "deps",
        "subtractive-ui"
      ]
    ],
    "subject-case": [0]
  }
}
